---
import { ClientRouter } from "astro:transitions";
interface Props {
    title?: string;
    description?: string;
}
const { title = "Media Vault", description = "Your personal media library" } =
    Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <ClientRouter />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Manrope:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <link rel="stylesheet" href="/styles/global.css" />
    </head>
    <body class={Astro.url.pathname === "/player" ? "is-player-page" : ""}>
        <header class="site-header">
            <a href="/" class="logo" aria-label="Media Vault Home">
                <span class="logo-icon">⬡</span>
                <span class="logo-text">Media<em>Vault</em></span>
            </a>

            <nav class="header-nav" aria-label="Main navigation">
                <a href="/" class="nav-link">Library</a>
                <a href="/player" class="nav-link">Now Playing</a>
            </nav>
        </header>

        <main id="main-content">
            <slot />
        </main>

        <div id="persistent-player-root" transition:persist>
            <div id="persistent-media-slot"></div>
            <div id="persistent-mini-player" class="mini-player hidden">
                <img id="mini-art" class="mini-art" src="/favicon.svg" alt="" />
                <div class="mini-info">
                    <span id="mini-title" class="mini-title"
                        >Nothing playing</span
                    >
                    <span id="mini-subtitle" class="mini-subtitle"
                        >Media Vault</span
                    >
                </div>
                <div class="mini-controls">
                    <button
                        id="mini-play-pause"
                        class="mini-btn play-pause"
                        aria-label="Play/Pause"
                    >
                        <span class="icon">⏵</span>
                    </button>
                    <a
                        href="/player"
                        id="mini-expand"
                        class="mini-btn"
                        aria-label="Expand player"
                    >
                        <span class="icon">⤢</span>
                    </a>
                </div>
            </div>
        </div>

        <footer class="site-footer">
            <span>Media Vault &mdash; local media server</span>
        </footer>

        <script>
            // Global state for the persistent player
            document.addEventListener("astro:page-load", () => {
                const isPlayerPage = window.location.pathname === "/player";
                const miniPlayer = document.getElementById(
                    "persistent-mini-player",
                );
                const playPauseBtn = document.getElementById("mini-play-pause");
                const mediaEl = document.getElementById(
                    "media-el",
                ) as HTMLMediaElement;

                // Show/hide mini player if playing and not on player page
                const updateMiniVisibility = () => {
                    if (!isPlayerPage && mediaEl && !mediaEl.paused) {
                        miniPlayer?.classList.remove("hidden");
                    } else if (isPlayerPage) {
                        miniPlayer?.classList.add("hidden");
                    }
                };

                // Sync play/pause button icon
                const updateIcon = () => {
                    if (playPauseBtn) {
                        const icon = playPauseBtn.querySelector(".icon");
                        if (icon)
                            icon.textContent = mediaEl?.paused ? "⏵" : "⏸";
                    }
                };

                if (mediaEl) {
                    mediaEl.addEventListener("play", () => {
                        updateMiniVisibility();
                        updateIcon();
                    });
                    mediaEl.addEventListener("pause", () => {
                        updateIcon();
                    });
                    updateIcon();
                    updateMiniVisibility();
                }

                if (playPauseBtn) {
                    playPauseBtn.onclick = () => {
                        if (!mediaEl) return;
                        if (mediaEl.paused) mediaEl.play();
                        else mediaEl.pause();
                    };
                }

                // Update navigation active states
                document.querySelectorAll(".nav-link").forEach((link) => {
                    const href = link.getAttribute("href");
                    if (href === window.location.pathname) {
                        link.classList.add("active");
                    } else {
                        link.classList.remove("active");
                    }
                });
            });
        </script>
    </body>
</html>
