---
import Base from "../layouts/Base.astro";
---

<Base title="Media Vault — Player" description="Now playing">
    <!-- Player page — all logic is handled client-side via query params -->
    <div id="player-root">
        <div class="loader" aria-live="polite" aria-label="Loading player">
            <span class="loader-dot"></span>
            <span class="loader-dot"></span>
            <span class="loader-dot"></span>
            <span>Loading player…</span>
        </div>
    </div>
</Base>

<script>
    import { navigate } from "astro:transitions/client";

    /* ============================================================
     Player page logic with persistent playback
     ============================================================ */

    type MediaType = "video" | "audio" | "directory";
    interface MediaItem {
        name: string;
        path: string;
        type: MediaType;
        ext?: string;
        size?: number;
    }

    const audioExts = new Set([
        ".mp3",
        ".flac",
        ".aac",
        ".ogg",
        ".opus",
        ".wav",
        ".m4a",
        ".wma",
    ]);

    function formatSize(bytes: number): string {
        if (bytes < 1_048_576) return (bytes / 1_024).toFixed(1) + " KB";
        if (bytes < 1_073_741_824)
            return (bytes / 1_048_576).toFixed(1) + " MB";
        return (bytes / 1_073_741_824).toFixed(2) + " GB";
    }

    function typeIcon(type: MediaType, ext?: string): string {
        if (type === "audio") return "🎵";
        const icons: Record<string, string> = {
            ".mkv": "🎬",
            ".mp4": "🎞️",
            ".webm": "🎥",
        };
        return icons[ext ?? ""] ?? "🎬";
    }

    function streamUrl(path: string): string {
        return `/api/stream?path=${encodeURIComponent(path)}`;
    }

    function fileName(path: string): string {
        return path.split("/").pop() ?? path;
    }

    function getMediaEl(isAudio: boolean): HTMLMediaElement {
        let el = document.getElementById("media-el") as HTMLMediaElement;
        const tag = isAudio ? "AUDIO" : "VIDEO";

        if (!el || el.tagName !== tag) {
            const oldEl = el;
            el = document.createElement(
                isAudio ? "audio" : "video",
            ) as HTMLMediaElement;
            el.id = "media-el";
            el.controls = true;
            el.autoplay = true;
            el.style.width = "100%";
            if (!isAudio) (el as HTMLVideoElement).style.maxHeight = "75dvh";
            el.setAttribute("preload", "metadata");
            el.setAttribute("playsinline", "");

            if (oldEl) oldEl.replaceWith(el);
        }
        return el;
    }

    function initPage() {
        const root = document.getElementById("player-root");
        if (!root) return;

        const params = new URLSearchParams(window.location.search);
        const filePath = params.get("path") ?? "";
        const queuePath = params.get("queue") ?? "";

        if (!filePath) {
            root.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">🎬</div>
                    <h1 class="empty-title">Nothing selected</h1>
                    <p class="empty-desc">Go to the <a href="/" style="color:var(--amber)">Library</a> and pick a file to play.</p>
                </div>`;
            return;
        }

        const ext = filePath.match(/\.[^.]+$/)?.[0]?.toLowerCase() ?? "";
        const isAudio = audioExts.has(ext);

        fetch(`/api/browse?path=${encodeURIComponent(queuePath)}`)
            .then((r) => r.json())
            .then(({ items }: { items: MediaItem[] }) => {
                const mediaItems = items.filter((i) => i.type !== "directory");
                renderPlayer(filePath, isAudio, mediaItems, ext, queuePath);
            })
            .catch(() => {
                renderPlayer(filePath, isAudio, [], ext, queuePath);
            });
    }

    function renderPlayer(
        path: string,
        isAudio: boolean,
        queue: MediaItem[],
        currentExt: string,
        queuePath: string,
    ) {
        const root = document.getElementById("player-root");
        if (!root) return;

        const name = fileName(path);
        const currentItem = queue.find((i) => i.path === path);
        const queueHtml =
            queue.length > 0
                ? `
            <div class="player-sidebar fade-in fade-in-delay-3">
                <div class="sidebar-header">Queue — ${queue.length} items</div>
                <ul class="queue-list" id="queue-list" role="list">
                    ${queue
                        .map(
                            (item) => `
                        <li class="queue-item${item.path === path ? " active" : ""}" role="button" tabindex="0" data-queue-path="${item.path}" data-queue-ext="${item.ext ?? ""}" data-queue-size="${item.size ?? ""}" data-queue-audio="${audioExts.has(item.ext ?? "") ? "true" : "false"}">
                            <span class="queue-icon">${typeIcon(item.type, item.ext)}</span>
                            <span class="queue-item-name">${item.name}</span>
                            ${item.size ? `<span class="queue-item-size">${formatSize(item.size)}</span>` : ""}
                        </li>`,
                        )
                        .join("")}
                </ul>
            </div>`
                : "";

        root.innerHTML = `
            <a href="/" class="breadcrumb">← Back to Library</a>
            <h1 class="now-playing-title fade-in">${name}</h1>
            <div class="now-playing-meta fade-in fade-in-delay-1"><span>${currentExt.replace(".", "").toUpperCase()}</span></div>
            <div class="player-layout fade-in fade-in-delay-2">
                <div class="player-main">
                    <div class="player-wrapper">
                        <div id="audio-metadata-row" class="audio-metadata-row" style="display:none;">
                            <div class="album-art-container"><img id="album-art" class="album-art" src="" alt="" style="display:none;" /></div>
                        </div>
                        <div id="player-media-target"></div>
                    </div>
                    <dl class="file-meta">
                        <div class="file-meta-item"><dt>Format</dt><dd>${currentExt.replace(".", "").toUpperCase() || "—"}</dd></div>
                        <div class="file-meta-item"><dt>Size</dt><dd>${currentItem?.size ? formatSize(currentItem.size) : "—"}</dd></div>
                        <div class="file-meta-item"><dt>Duration</dt><dd id="meta-duration">—</dd></div>
                        ${!isAudio ? `<div class="file-meta-item"><dt>Resolution</dt><dd id="meta-resolution">—</dd></div>` : ""}
                        <div class="file-meta-item"><dt>Filename</dt><dd class="meta-filename">${name}</dd></div>
                        <div class="file-meta-item" id="meta-description-row" style="display:none; flex: 1 1 100%;"><dt>Description</dt><dd id="meta-description" class="audio-description"></dd></div>
                    </dl>
                </div>
                ${queueHtml}
            </div>`;

        // Handle the persistent media el
        const mediaEl = getMediaEl(isAudio);
        const target = document.getElementById("player-media-target");
        if (target) target.appendChild(mediaEl);

        // Update source only if it's a different file
        const newSrc = streamUrl(path);
        if (mediaEl.src !== window.location.origin + newSrc) {
            mediaEl.src = newSrc;
            mediaEl.load();
            mediaEl.play().catch(() => {});
        }

        attachQueueHandlers(path, queuePath);
        attachMediaMetaListener(mediaEl);
        updateAudioMetadata(path);
        updateGlobalMiniPlayer(path, currentExt, queuePath);
    }

    function updateGlobalMiniPlayer(
        path: string,
        ext: string,
        queuePath: string,
    ) {
        const title = document.getElementById("mini-title");
        const subtitle = document.getElementById("mini-subtitle");
        const art = document.getElementById("mini-art") as HTMLImageElement;
        const miniLink = document.getElementById(
            "mini-link",
        ) as HTMLAnchorElement;
        const expandBtn = document.getElementById(
            "mini-expand",
        ) as HTMLAnchorElement;

        if (title) title.textContent = fileName(path);
        if (subtitle) subtitle.textContent = ext.replace(".", "").toUpperCase();
        if (art) art.src = `/api/album-art?path=${encodeURIComponent(path)}`;

        const playerUrl = `/player?path=${encodeURIComponent(path)}&queue=${encodeURIComponent(queuePath)}`;
        if (miniLink) miniLink.href = playerUrl;
        if (expandBtn) expandBtn.href = playerUrl;
    }

    function attachMediaMetaListener(el: HTMLMediaElement) {
        const onMeta = () => {
            const durEl = document.getElementById("meta-duration");
            if (durEl) {
                const secs = el.duration;
                if (isFinite(secs) && secs > 0) {
                    const h = Math.floor(secs / 3600),
                        m = Math.floor((secs % 3600) / 60),
                        s = Math.floor(secs % 60);
                    durEl.textContent =
                        h > 0
                            ? `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`
                            : `${m}:${String(s).padStart(2, "0")}`;
                }
            }
            if (el instanceof HTMLVideoElement) {
                const resEl = document.getElementById("meta-resolution");
                if (resEl && el.videoWidth)
                    resEl.textContent = `${el.videoWidth} × ${el.videoHeight}`;
            }
        };
        el.addEventListener("loadedmetadata", onMeta, { once: true });
        if (el.readyState >= 1) onMeta();
    }

    async function updateAudioMetadata(path: string) {
        const metaRow = document.getElementById("audio-metadata-row");
        const artImg = document.getElementById("album-art") as HTMLImageElement;
        const descRow = document.getElementById("meta-description-row");
        const descEl = document.getElementById("meta-description");
        if (!metaRow || !artImg || !descEl || !descRow) return;

        const musicExts = [".mp3", ".m4a", ".flac", ".ogg", ".opus", ".wav"];
        if (
            !musicExts.includes(
                path.match(/\.[^.]+$/)?.[0]?.toLowerCase() ?? "",
            )
        )
            return;

        try {
            const res = await fetch(
                `/api/metadata?path=${encodeURIComponent(path)}`,
            );
            if (!res.ok) return;
            const data = await res.json();
            if (data.hasArt) {
                artImg.src = `/api/album-art?path=${encodeURIComponent(path)}&t=${Date.now()}`;
                artImg.style.display = "block";
                metaRow.style.display = "flex";
            }
            if (data.comment) {
                descEl.textContent = Array.isArray(data.comment)
                    ? data.comment.join("\n")
                    : String(data.comment);
                descRow.style.display = "flex";
            }
        } catch {}
    }

    function attachQueueHandlers(activePath: string, queuePath: string) {
        const queueList = document.getElementById("queue-list");
        if (!queueList) return;
        queueList
            .querySelectorAll<HTMLElement>("[data-queue-path]")
            .forEach((el) => {
                el.addEventListener("click", () => {
                    const newPath = el.dataset.queuePath!;
                    navigate(
                        `/player?path=${encodeURIComponent(newPath)}&queue=${encodeURIComponent(queuePath)}`,
                    );
                });
            });
    }

    // View Transitions lifecycle
    document.addEventListener("astro:page-load", initPage);

    document.addEventListener("astro:before-preparation", () => {
        // Move media-el back to persistent slot before the swap
        const mediaEl = document.getElementById("media-el");
        const slot = document.getElementById("persistent-media-slot");
        if (mediaEl && slot) {
            slot.appendChild(mediaEl);
        }
    });
</script>
